<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ZoniqFi - Connect Wallet</title>
    <style>
        /* --- CSS STYLING (Tema Gelap ala DeFi) --- */
        body {
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #0b0e14;
            color: #ffffff;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 40px;
            background-color: #111622;
            border-bottom: 1px solid #1f293d;
        }

        .logo {
            font-size: 24px;
            font-weight: bold;
            color: #0052FF; /* Warna Khas Base Network */
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* Desain Tombol Connect Wallet */
        .web3-btn {
            background: linear-gradient(135deg, #0052FF 0%, #003db3 100%);
            color: white;
            border: none;
            padding: 12px 24px;
            font-size: 16px;
            font-weight: 600;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(0, 82, 255, 0.3);
        }

        .web3-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0, 82, 255, 0.5);
        }

        .web3-btn:active {
            transform: translateY(0);
        }

        main {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .card {
            background-color: #111622;
            border: 1px solid #1f293d;
            border-radius: 24px;
            padding: 40px;
            text-align: center;
            max-width: 400px;
            width: 100%;
        }

        h1 { margin-top: 0; font-size: 28px; }
        p { color: #8a9fc2; line-height: 1.6; }
    </style>
</head>
<body>

    <header>
        <div class="logo">⚡ ZoniqFi</div>
        <!-- Tombol Khusus Web3Modal dari Script -->
        <appkit-button></appkit-button>
    </header>

    <main>
        <div class="card">
            <h1>Selamat Datang</h1>
            <p>Hubungkan dompet Anda untuk mulai berinteraksi dengan brankas likuiditas di jaringan Base L2.</p>
            <!-- Tombol alternatif di tengah halaman -->
            <appkit-button></appkit-button>
        </div>
    </main>

    <!-- --- JAVASCRIPT INTEGRATION --- -->
    <!-- Mengunduh AppKit (Web3Modal) khusus untuk Vanilla JS / HTML via CDN -->
    <script type="module">
        import { createAppKit } from 'https://esm.sh'
        import { mainnet, base } from 'https://esm.sh/networks'

        // 1. Ambil Project ID gratis dari https://walletconnect.com
        const projectId = 'YOUR_WALLETCONNECT_PROJECT_ID'; 

        // 2. Konfigurasi dan Inisialisasi Modal
        const appkit = createAppKit({
            adapters: [], 
            networks: [base], // Mengunci aplikasi agar fokus utama di Base Network
            metadata: {
                name: 'ZoniqFi Dashboard',
                description: 'ZoniqFi Wallet Configuration',
                url: window.location.origin,
                icons: ['https://githubusercontent.com']
            },
            projectId,
            features: {
                analytics: true,
                email: true, // Mengaktifkan opsi ke-4: Login Sosial via Email/Google (Web3Auth alternatif)
                socials: ['google', 'apple', 'x', 'discord'], // Login instan tanpa download wallet
            },
            themeMode: 'dark', // Menyesuaikan dengan CSS tema gelap kita
            themeVariables: {
                '--w3m-accent': '#0052FF', // Mengubah warna utama modal menjadi biru Base
                '--w3m-border-radius-master': '12px'
            }
        })

        // Pengaturan opsional: Deteksi jika user berhasil terhubung
        appkit.subscribeAccount(account => {
            if (account.isConnected) {
                console.log("Wallet terhubung ke alamat:", account.address);
            }
        });
    </script>
</body>
</html>
